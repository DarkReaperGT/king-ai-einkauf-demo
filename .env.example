OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.5
PORT=3000
HOST=0.0.0.0

LOGIN_USERNAME=unternehmen
LOGIN_PASSWORD=Bitte_Aendern_123!
SESSION_SECRET=Bitte_Diesen_Wert_Aendern_Sehr_Lang_123456789

# Auf Render.com läuft die App hinter HTTPS. NODE_ENV=production sorgt
# automatisch für sichere Cookies. Lokal (http://localhost) leer lassen
# oder auf false setzen, sonst funktioniert der Login im Browser nicht.
NODE_ENV=production
# Optional: überschreibt die automatische Erkennung oben.
# COOKIE_SECURE=true
SESSION_HOURS=8
